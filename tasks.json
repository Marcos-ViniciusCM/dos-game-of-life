 {
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Build com Open Watcom (16-bit DOS)",
            "command": "wcl",
            "args": [
                "-bt=dos",
                "-ms",
                "${file}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$mscompile"
        }
    ]
}